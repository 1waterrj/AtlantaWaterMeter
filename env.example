# Copy to .env and adjust. Used by docker compose.

# --- Meter ---
# Leave unset to run in debug mode (discover meter IDs in logs).
# METERID=

# METRIC=1

# --- Timing (optional) ---
# POLL_INTERVAL_SEC=60
# RTL_TCP_STARTUP_SEC=10
# WATCHDOG_MINUTES=30

# --- MQTT (Home Assistant) ---
# MQTT_HOST=homeassistant.local
# MQTT_PORT=1883
# MQTT_TOPIC_PREFIX=home/water_meter
# MQTT_USER=
# MQTT_PASSWORD=
# MQTT_TLS=1
# MQTT_RETAIN=1
# MQTT_PUBLISH_RADIO=1
# MQTT_DISABLE_DISCOVERY=0
# MQTT_DISCOVERY_PREFIX=homeassistant
# MQTT_DEVICE_NAME=Water meter
# MQTT_SW_VERSION=1.0
# Optional explicit availability topic (default: {reading_topic}/availability sibling)
# MQTT_AVAILABILITY_TOPIC=

# Only publish MQTT when consumption changes (still touches health log every cycle)
# MQTT_PUBLISH_ON_CHANGE=0
# If MQTT_PUBLISH_ON_CHANGE=1, force a publish at least this often (seconds) even if unchanged
# MQTT_HEARTBEAT_SEC=3600

# --- Watchdog (optional) ---
# WATCHDOG_REBOOT_CMD=

# --- HTTP logging (optional) ---
# CURL_API=

# --- Healthcheck (optional) ---
# HEALTHCHECK_MAX_AGE_SEC=2400
# HEALTHCHECK_LOG=updated.log

# TZ=America/New_York
